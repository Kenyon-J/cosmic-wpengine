{
    "app-id": "com.system76.CosmicWallpaper",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "cosmic-wallpaper",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=pipewire",
        "--filesystem=xdg-config/cosmic:ro",
        "--filesystem=host:ro",
        "--talk-name=org.mpris.MediaPlayer2.*",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=org.freedesktop.portal.Background",
        "--talk-name=org.freedesktop.portal.Desktop"
    ],
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "build-args": [
            "--share=network"
        ],
        "env": {
            "CARGO_HOME": "/run/build/cosmic-wallpaper/cargo",
            "RUSTUP_TOOLCHAIN": "stable"
        }
    },
    "modules": [
        {
            "name": "cosmic-wallpaper",
            "buildsystem": "simple",
            "build-commands": [
                "cargo build --release --all-targets",
                "install -Dm0755 target/release/cosmic-wallpaper /app/bin/cosmic-wallpaper",
                "install -Dm0755 target/release/cosmic-wallpaper-gui /app/bin/cosmic-wallpaper-gui"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}